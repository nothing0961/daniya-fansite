# Auth.js v5 密钥 — 生成命令: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# Neon Serverless PostgreSQL
# 在 Neon Dashboard → Connection Details 获取
# DATABASE_URL — Pooled 连接（带 -pooler 后缀，用于运行时查询）
# DIRECT_URL  — Direct 连接（不带 -pooler，用于 Prisma migrations）
DATABASE_URL="postgresql://user:password@host-neon-pooler/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@host-neon/neondb?sslmode=require"

# 站点 URL（生产环境设置为实际域名）
AUTH_URL=http://localhost:3000

# 管理员用户 ID — 注册后在数据库中查你的用户 ID 填入
ADMIN_USER_ID=your-user-id

# ImgURL 图床 API 凭证 (https://www.imgurl.org/vip/user → API Token)
IMGURL_UID=your-uid
IMGURL_TOKEN=your-token

# ============================================================
# AI 聊天双轨配置（默认模型 + 用户自定义密钥）
# ============================================================
# 默认模型 L1：智谱 GLM-4.7-Flash（永久免费，国内直连）
#   获取地址：https://open.bigmodel.cn  → 注册手机号 + 实名 → API Keys 新建
#   ⚠️ 安全：密钥只填 .env.local / Vercel Environment Variables，永远不要提交到 Git
ZHIPU_API_KEY="your-zhipu-api-key-xxxx.xxxx"
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_DEFAULT_MODEL=glm-4.7-flash

# 默认模型 L2：限流/输出长度（用户自定义密钥模式下不生效，用户自己掏钱无限流）
CHAT_DAILY_QUOTA_PER_USER=200
CHAT_MAX_OUTPUT_TOKENS=50

# 自定义密钥 localStorage AES-GCM HKDF salt（保持默认即可，多项目共用时才改，防止跨站串密文）
USER_KEY_ENCRYPTION_SALT=daniya-custom-ai-v1
