# Auth.js v5 密钥 — 生成命令: openssl rand -base64 32
AUTH_SECRET=your-secret-here

# GitHub OAuth 应用 (https://github.com/settings/developers)
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# QQ OAuth 应用 (https://connect.qq.com/)
# 回调 URL: https://你的域名/api/auth/callback/qq
AUTH_QQ_ID=your-qq-app-id
AUTH_QQ_SECRET=your-qq-app-secret

# 邮箱 Magic Link — SendCloud (https://sendcloud.net)
# API 密钥在 SendCloud 后台 → 邮件设置 → API 设置
EMAIL_FROM="达妮娅的瞌睡小屋 <noreply@your-domain.com>"
SENDCLOUD_API_USER=your-sendcloud-api-user
SENDCLOUD_API_KEY=your-sendcloud-api-key

# 腾讯云短信 (https://console.cloud.tencent.com/smsv2)
# 在腾讯云 CAM 创建 API 密钥并开通短信服务
TENCENT_SMS_SECRET_ID=your-secret-id
TENCENT_SMS_SECRET_KEY=your-secret-key
TENCENT_SMS_SDK_APP_ID=your-sdk-app-id
TENCENT_SMS_SIGN_NAME=达妮娅的瞌睡小屋
TENCENT_SMS_TEMPLATE_ID=your-template-id

# Neon Serverless PostgreSQL
# 在 Neon Dashboard → Connection Details 获取
# DATABASE_URL — Pooled 连接（带 -pooler 后缀，用于运行时查询）
# DIRECT_URL  — Direct 连接（不带 -pooler，用于 Prisma migrations）
DATABASE_URL="postgresql://user:password@host-neon-pooler/neondb?sslmode=require"
DIRECT_URL="postgresql://user:password@host-neon/neondb?sslmode=require"

# 站点 URL（生产环境设置为实际域名，邮箱 Magic Link 回调用）
AUTH_URL=http://localhost:3000

# Giscus 评论配置 (https://giscus.app)
NEXT_PUBLIC_GISCUS_REPO=your-github-username/your-repo
NEXT_PUBLIC_GISCUS_REPO_ID=your-repo-id
NEXT_PUBLIC_GISCUS_CATEGORY=Announcements
NEXT_PUBLIC_GISCUS_CATEGORY_ID=your-category-id
